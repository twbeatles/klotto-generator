{
  "typeCheckingMode": "standard",
  "pythonVersion": "3.10",
  "venvPath": ".",
  "venv": ".venv",
  "executionEnvironments": [
    {
      "root": ".",
      "extraPaths": [
        "."
      ]
    }
  ],
  "include": [
    "**/*.py"
  ],
  "exclude": [
    "**/__pycache__",
    ".git",
    ".venv",
    "venv",
    "build",
    "dist"
  ]
}
